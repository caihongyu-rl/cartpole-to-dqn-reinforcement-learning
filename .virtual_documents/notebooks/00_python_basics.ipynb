# mario-square-1

def main():
    print_square(3)

def print_square(size):
    
    # for each row in square
    for i in range(size):

        # for each brick in row
        for j in range(size):

            # print break
            print("#", end = "")

        # after print each brick in row, we need to let the cursor on next line
        print()

main()


# mario-square-2

def main():
    print_square(3)

def print_square(size):
    for i in range(size):
        print_row(size)

def print_row(width):
    print("#" * width)

main()
        





