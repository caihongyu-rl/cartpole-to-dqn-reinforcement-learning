# try-except

try:
    x = int(input("what's x? "))
    print(f"x is {x}")
except ValueError:
    print("x is not an integer")


# interesting phenomenon-NameError
# int("hello") is wrong, so x don't be evaluation，name 'x' is not defined

try:
    x = int(input("what's x? "))
except ValueError:
    print("x is not an integer")

print(f"x is {x}")


# try-except-else
# if the program don't have the error we can execute else,
# if the program have the error we execute except and skip else

try:
    x = int(input("what's x? "))
except ValueError:
    print("x is not an integer")
else:
    print(f"x is {x}")


while True:
    try:
        x = int(input("what's x? "))
    except ValueError:
        print("x is not an integer")
    else:
        break

print(f"x is {x}")


def main():
    x = get_int()
    print(f"x is {x}")

def get_int():

    while True:
        try:
            x = int(input("what's x? "))
            return x
        except ValueError:
            print("x is not integer")

main()


# pass

def main():
    x = get_int()
    print(f"x is {x}")

def get_int():

    while True:
        try:
            x = int(input("what's x? "))
            return x
        except ValueError:
            pass

main()


def main():
    x = get_int("what's x? ")
    print(f"x is {x}")

def get_int(prompt):

    while True:
        try:
            return int(input(prompt))
        except ValueError:
            pass

main()





