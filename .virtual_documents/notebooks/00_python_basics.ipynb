# for loop

for i in [0, 1, 2]:
    print("miao")
     


# use the range function in for loop

for i in range(3):
    print("miao")


# use "_" variable don't care about name in for loop

for _ in range(3):
    print("miao")


print("miao\n" * 3, end = "")


# use while true to create a infinite loop to check the state

while True:
    n = int(input("what's n? "))
    if n > 0:
        break

for _ in range(n):
    print("miao")



# create a miao function 
def main():
    number = get_number()
    miao(number)

def get_number():
    while True:
        n = int(input("what's number? "))
        if n > 0:
            break
    return n

def miao(n):
    for _ in range(n):
        print("miao")

main()




